---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Distributors & Partners | Neovantis"
  description="Partner with Neovantis as a medical device distributor. Explore distribution opportunities across South Africa and the broader African market."
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="page-hero-bg" style="background-image:url('/images/distributors and partners hero.png')"></div>
    <div class="page-hero-overlay"></div>
    <div class="container">
      <div class="page-hero-content">
        <p style="font-family:var(--font-display);font-size:0.8rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--blue-accent);margin-bottom:0.5rem;">Partner With Us</p>
        <h1>Distributors &<br/>Partners</h1>
        <div class="accent-bar" style="margin-left:auto;"></div>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="section section--lg">
    <div class="container">
      <div class="grid-2" style="align-items:center;gap:4rem;">
        <div>
          <p style="font-family:var(--font-display);font-size:0.8rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--blue-accent);margin-bottom:0.75rem;">Distribution Opportunities</p>
          <h2 style="margin-bottom:1rem;">Expand Your Medical<br/>Device Portfolio</h2>
          <span class="accent-bar"></span>
          <p style="margin-bottom:1.5rem;">Neovantis is actively seeking qualified medical device distribution partners across South Africa and the broader African market. We offer competitive terms, strong product lines, and full marketing support to help our distribution partners succeed.</p>
          <p style="margin-bottom:2rem;">Whether you are an established surgical equipment distributor or a regional medical device specialist, we want to explore how a Neovantis partnership can strengthen your offering to hospitals, surgical centres, and specialist practices.</p>
          <a href="#partner-form" class="btn btn-primary">Apply to Become a Partner</a>
        </div>
        <div style="border-radius:8px;overflow:hidden;border:1px solid rgba(31,127,182,0.3);">
          <img src="/images/neovantis-distributor.png" ... />
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="angled-panel">
    <div class="geo-overlay"></div>
    <div class="container" style="position:relative;z-index:2;">
      <div class="section-heading">
        <h2>Benefits of Partnership</h2>
        <div class="section-divider"></div>
        <p>Neovantis distribution partners receive comprehensive support to maximise their success in the medical device market.</p>
      </div>
      <div class="grid-3">
        {[
          { icon: '💼', title: 'Competitive Margins', desc: 'Attractive distributor pricing structures with volume-based incentives and performance bonuses for top-performing partners.' },
          { icon: '📦', title: 'Reliable Stock Supply', desc: 'Consistent inventory availability backed by our local warehouse and international supplier network, minimising back-order disruptions.' },
          { icon: '🎓', title: 'Full Product Training', desc: 'Comprehensive training on all product lines — including clinical applications, surgical technique, and sales positioning — for your distribution team.' },
          { icon: '📣', title: 'Marketing Support', desc: 'Access to Neovantis marketing materials, digital assets, product brochures, and co-branded collateral for your territory.' },
          { icon: '🤝', title: 'Dedicated Partner Manager', desc: 'A dedicated Neovantis partner manager assigned to your account for ongoing support, forecasting, and business development.' },
          { icon: '🌍', title: 'Exclusive Territories', desc: 'Territory exclusivity available for qualifying partners demonstrating capability and commitment in defined geographic regions.' },
        ].map(item => (
          <div class="card">
            <div class="feature-icon">{item.icon}</div>
            <h4 style="margin-bottom:0.75rem;">{item.title}</h4>
            <p style="font-size:0.9rem;">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Requirements -->
  <section class="section section--lg" style="background:#040c16;">
    <div class="container">
      <div class="section-heading">
        <h2>Partner Requirements</h2>
        <div class="section-divider"></div>
        <p>We seek distributors with the experience and infrastructure to represent Neovantis products professionally in the market.</p>
      </div>
      <div class="grid-2" style="gap:2rem;">
        {[
          { title: 'Established Medical Device Experience', desc: 'Demonstrated track record in medical device distribution within South Africa or relevant African markets.' },
          { title: 'Regulatory Compliance', desc: 'Current SAHPRA registration or willingness to obtain applicable regulatory authorisations for device distribution.' },
          { title: 'Healthcare Sector Relationships', desc: 'Existing relationships with hospitals, surgical centres, private practices, or procurement committees in your target territory.' },
          { title: 'Technical Capability', desc: 'Capacity to provide basic product training and intraoperative support to healthcare professionals in your region.' },
        ].map(item => (
          <div class="card" style="display:flex;gap:1.25rem;">
            <span style="color:var(--blue-accent);font-size:1.5rem;flex-shrink:0;margin-top:2px;">✓</span>
            <div>
              <h4 style="margin-bottom:0.5rem;">{item.title}</h4>
              <p style="font-size:0.9rem;">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Partner Form -->
  <section class="section section--lg" id="partner-form">
    <div class="container">
      <div class="grid-2" style="gap:4rem;align-items:start;">
        <div>
          <p style="font-family:var(--font-display);font-size:0.8rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--blue-accent);margin-bottom:0.75rem;">Get Started</p>
          <h2 style="margin-bottom:1rem;">Distributor Enquiry</h2>
          <span class="accent-bar"></span>
          <p style="margin-bottom:1.5rem;">Complete the form below to express your interest in a Neovantis distribution partnership. A member of our business development team will contact you within 3 business days.</p>
          <div class="contact-info-item">
            <div class="contact-info-icon">📞</div>
            <div class="contact-info-text">
              <h4>Direct Line</h4>
              <a href="tel:+27314631188">031 463 1188</a>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="contact-info-icon">✉️</div>
            <div class="contact-info-text">
              <h4>Email</h4>
              <a href="mailto:info@neovantis.co.za">info@neovantis.co.za</a>
            </div>
          </div>
        </div>
        <div>
          <form
            name="distributor-enquiry"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="card"
            style="padding:2rem;"
          >
            <input type="hidden" name="form-name" value="distributor-enquiry" />
            <input type="hidden" name="bot-field" />
            <div class="form-row">
              <div class="form-group">
                <label>First Name *</label>
                <input type="text" name="first_name" required />
              </div>
              <div class="form-group">
                <label>Last Name *</label>
                <input type="text" name="last_name" required />
              </div>
            </div>
            <div class="form-group">
              <label>Company / Organisation *</label>
              <input type="text" name="company" required />
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Email *</label>
                <input type="email" name="email" required />
              </div>
              <div class="form-group">
                <label>Phone *</label>
                <input type="tel" name="phone" required />
              </div>
            </div>
            <div class="form-group">
              <label>Target Territory / Region</label>
              <input type="text" name="territory" placeholder="e.g. Gauteng, Western Cape, East Africa" />
            </div>
            <div class="form-group">
              <label>Current Medical Device Lines</label>
              <textarea name="current_lines" rows="3" placeholder="Briefly describe your current product lines and customer base"></textarea>
            </div>
            <div class="form-group">
              <label>Message</label>
              <textarea name="message" rows="3" placeholder="Tell us about your distribution interest"></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:0.5rem;">Submit Enquiry</button>
          </form>
        </div>
      </div>
    </div>
  </section>

</MainLayout>
