---
interface Props {
  category: string;
  title: string;
  description: string;
  image: string;
  specs?: { label: string; value: string }[];
  brochureLabel?: string;
}
const { category, title, description, image, specs = [], brochureLabel = 'Download Brochure' } = Astro.props;
---

<div class="product-card">
  <div class="product-card-image">
    <img src={image} alt={title} loading="lazy" />
  </div>
  <div class="product-card-body">
    <p class="product-category">{category}</p>
    <h3>{title}</h3>
    <p>{description}</p>

    {specs.length > 0 && (
      <div class="product-specs">
        <table>
          <tbody>
            {specs.map(s => (
              <tr>
                <td>{s.label}</td>
                <td>{s.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    <div style="display:flex; gap:0.75rem; flex-wrap:wrap; margin-top:1.25rem;">
      <a href="/contact" class="btn btn-ghost" style="font-size:0.8rem; padding:0.6rem 1.25rem;">Request Info</a>
      <button
        onclick="alert('Brochure download available on request. Contact info@neovantis.co.za')"
        class="btn btn-outline"
        style="font-size:0.8rem; padding:0.6rem 1.25rem;"
      >
        📄 {brochureLabel}
      </button>
    </div>
  </div>
</div>
