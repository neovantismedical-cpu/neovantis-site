---
import Logo from './Logo.astro';
---

<nav class="navbar" id="navbar">
  <div class="container">
    <div class="navbar-inner">
      <a href="/" class="navbar-logo">
        <Logo size="md" />
      </a>

      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about">About Us</a></li>
        <li><a href="/solutions">Solutions</a></li>
        <li><a href="/products">Products</a></li>
        <li><a href="/healthcare-professionals">For Professionals</a></li>
        <li><a href="/distributors">Distributors</a></li>
        <li><a href="/blog">Blog</a></li>
      </ul>

      <div class="nav-cta">
        <a href="/contact" class="btn btn-primary">Contact Us</a>
      </div>

      <button
        class="hamburger"
        id="hamburger"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobileMenu"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile Menu — fixed panel that slides in below the navbar -->
<div class="mobile-menu" id="mobileMenu" role="navigation" aria-label="Mobile navigation">
  <a href="/" onclick="closeMobile()">Home</a>
  <a href="/about" onclick="closeMobile()">About Us</a>
  <a href="/solutions" onclick="closeMobile()">Solutions</a>
  <a href="/products" onclick="closeMobile()">Products</a>
  <a href="/healthcare-professionals" onclick="closeMobile()">For Professionals</a>
  <a href="/distributors" onclick="closeMobile()">Distributors</a>
  <a href="/blog" onclick="closeMobile()">Blog</a>
  <div class="mobile-cta">
    <a href="/contact" onclick="closeMobile()" class="btn btn-primary">Contact Us</a>
  </div>
</div>

<script>
  const navbar = document.getElementById('navbar');
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');

  function updateMenuPosition() {
    if (navbar && mobileMenu) {
      mobileMenu.style.top = navbar.getBoundingClientRect().height + 'px';
    }
  }

  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 30);
    if (mobileMenu?.classList.contains('open')) {
      updateMenuPosition();
    }
  }, { passive: true });

  window.addEventListener('resize', () => {
    updateMenuPosition();
    if (window.innerWidth > 900) {
      closeMobile();
    }
  });

  hamburger?.addEventListener('click', () => {
    updateMenuPosition();
    const isOpen = mobileMenu?.classList.contains('open');
    if (isOpen) {
      closeMobile();
    } else {
      mobileMenu?.classList.add('open');
      hamburger?.classList.add('active');
      hamburger?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
  });

  function closeMobile() {
    mobileMenu?.classList.remove('open');
    hamburger?.classList.remove('active');
    hamburger?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }
  (window as any).closeMobile = closeMobile;

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMobile();
  });

  updateMenuPosition();
</script>

<style>
  /* ── Logo: constrain size so it never crowds the hamburger ── */
  .navbar-logo img {
    width: 220px;
    max-width: 100%;
    height: auto;
  }

  /* ── Hamburger: hidden on desktop ── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    cursor: pointer;
    /* 44×44 minimum touch target */
    width: 44px;
    height: 44px;
    padding: 0;
    background: none;
    border: none;
    flex-shrink: 0;
    border-radius: 4px;
  }

  /* ── Mobile menu: hidden by default ── */
  .mobile-menu {
    display: none;
  }

  .mobile-menu.open {
    display: flex;
    flex-direction: column;
  }

  /* ── 900px breakpoint: switch to mobile layout ── */
  @media (max-width: 900px) {
    .nav-links,
    .nav-cta {
      display: none;
    }

    .hamburger {
      display: inline-flex;
    }
  }

  /* ── Small phones ≤400px: shrink logo further to prevent overlap ── */
  @media (max-width: 400px) {
    .navbar-logo img {
      width: 160px;
    }
  }
</style>
