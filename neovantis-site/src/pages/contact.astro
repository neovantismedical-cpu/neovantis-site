---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Contact Us | Neovantis"
  description="Contact the Neovantis team in Durban, South Africa. Request a quote, product information, or speak with a clinical support specialist."
>

  <!-- Page Hero — matches screenshot exactly -->
  <section class="page-hero" style="min-height:60vh;">
    <div class="page-hero-bg" style="background-image:url('/images/Contact us hero.png')"></div>
    <div class="page-hero-overlay"></div>
    <div class="container">
      <div class="page-hero-content">
        <p style="font-family:var(--font-display);font-size:0.8rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--blue-accent);margin-bottom:0.5rem;">Get in Touch</p>
        <h1>Contact Us</h1>
        <div class="accent-bar" style="margin-left:auto;margin-top:0.75rem;width:120px;height:5px;"></div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="section section--lg">
    <div class="container">
      <div class="section-heading">
        <h2>Request a Quote</h2>
        <div class="section-divider"></div>
        <p>Complete the form below or reach us directly. Our team responds to all enquiries within 1 business day.</p>
      </div>

      <div class="grid-2" style="gap:4rem;align-items:start;">

        <!-- Contact Info -->
        <div>
          <h3 style="margin-bottom:2rem;font-size:1.4rem;">Contact Information</h3>

          <div class="contact-info-item">
            <div class="contact-info-icon">📍</div>
            <div class="contact-info-text">
              <h4>Location</h4>
              <p>Durban, KwaZulu-Natal<br/>South Africa</p>
            </div>
          </div>

          <div class="contact-info-item">
            <div class="contact-info-icon">📞</div>
            <div class="contact-info-text">
              <h4>Telephone</h4>
              <a href="tel:+27314631188">031 463 1188</a>
            </div>
          </div>

          <div class="contact-info-item">
            <div class="contact-info-icon">💬</div>
            <div class="contact-info-text">
              <h4>WhatsApp</h4>
              <a href="https://wa.me/27745630777">074 563 0777</a>
            </div>
          </div>

          <div class="contact-info-item">
            <div class="contact-info-icon">✉️</div>
            <div class="contact-info-text">
              <h4>Email</h4>
              <a href="mailto:info@neovantis.co.za">info@neovantis.co.za</a>
            </div>
          </div>

          <div style="margin-top:2.5rem;padding:1.5rem;border:1px solid var(--border);border-radius:var(--radius-lg);background:var(--bg-card);">
            <h4 style="font-size:0.8rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--blue-accent);margin-bottom:0.75rem;">Office Hours</h4>
            <p style="font-size:0.9rem;">Monday – Friday: 08:00 – 17:00</p>
            <p style="font-size:0.9rem;">Saturday: 08:00 – 13:00 (by appointment)</p>
            <p style="font-size:0.9rem;">Sunday: Closed</p>
          </div>

          <div style="margin-top:1.5rem;">
            <a href="https://wa.me/27745630777" class="btn btn-primary" style="width:100%;justify-content:center;">
              💬 WhatsApp Us Now
            </a>
          </div>
        </div>

        <!-- Form -->
        <div>
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="card"
            style="padding:2.5rem;"
          >
            <input type="hidden" name="form-name" value="contact" />
            <input type="hidden" name="bot-field" />

            <div class="form-row">
              <div class="form-group">
                <label>Name *</label>
                <input type="text" name="name" required placeholder="Your full name" />
              </div>
              <div class="form-group">
                <label>Practice / Organisation</label>
                <input type="text" name="organisation" placeholder="Hospital, practice, or company" />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label>Email *</label>
                <input type="email" name="email" required placeholder="your@email.com" />
              </div>
              <div class="form-group">
                <label>Phone</label>
                <input type="tel" name="phone" placeholder="e.g. 031 xxx xxxx" />
              </div>
            </div>

            <div class="form-group">
              <label>Subject / Product of Interest</label>
              <select name="subject">
                <option value="">Select a topic</option>
                <option value="orthopaedic-hardware">Orthopaedic Trauma Hardware</option>
                <option value="rf-ablation">RF Ablation Equipment</option>
                <option value="quote">Request a Quote</option>
                <option value="distribution">Distribution Partnership</option>
                <option value="clinical-support">Clinical Support</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="form-group">
              <label>Message *</label>
              <textarea name="message" required placeholder="Please describe your requirement or enquiry in as much detail as possible." rows="6"></textarea>
            </div>

            <div class="alert" style="font-size:0.82rem;margin-bottom:1rem;">
              By submitting this form you agree to our <a href="/privacy-policy" style="color:var(--blue-accent);">Privacy Policy</a>. Your information will be used to respond to your enquiry only.
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;font-size:1rem;padding:1rem;">
              Send Message →
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>

</MainLayout>
