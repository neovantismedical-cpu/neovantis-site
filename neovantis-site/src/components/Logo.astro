---
interface Props {
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { size = 'md', class: className = '' } = Astro.props;

const widths = { sm: 180, md: 250, lg: 330 };
const w = widths[size];
---
<img
  src="/images/neovantis-logo.png"
  alt="Neovantis - Improving Lives Together"
  width={w}
  class={className}
  style="height: auto; display: block;"
/>